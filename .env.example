# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ─── Google OAuth2 (Gmail) ────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "Gmail API"
# 3. OAuth consent screen → Add scopes:
#      gmail.readonly, gmail.modify, email, profile
# 4. Credentials → Create OAuth 2.0 Client ID (Web application)
# 5. Add redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Microsoft OAuth2 (Outlook) ──────────────────────────────────────────────
# 1. Go to https://portal.azure.com/ → Azure Active Directory → App registrations
# 2. Register new app → Add redirect URI
# 3. API permissions → Add: Mail.Read, Mail.ReadWrite, User.Read
# 4. Generate a client secret
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Supabase, Railway, or local Postgres)
# After setting this, run: npx prisma migrate dev --name init
# Pooler URL (used by the running app — fast, connection pooling)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-x-us-east-x.pooler.supabase.com:6543/postgres

# Direct URL (used only for migrations — bypasses the pooler)
# In Supabase: Settings → Database → Connection string → URI (NOT the pooler one)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-random-64-byte-hex
JWT_REFRESH_SECRET=replace-with-different-random-64-byte-hex

# ─── Credential Encryption ────────────────────────────────────────────────────
# Used to encrypt stored IMAP passwords and OAuth refresh tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-random-32-byte-hex-64-chars

# ─── Anthropic AI (Premium: smart filters) ───────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# 1. Create a Stripe account at https://stripe.com
# 2. Dashboard → Developers → API keys → copy Secret key
STRIPE_SECRET_KEY=sk_test_...

# 3. Create two products with monthly prices (Dashboard → Products)
#    Copy each price's ID (starts with price_...)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# 4. Dashboard → Developers → Webhooks → Add endpoint
#    URL: https://your-domain.com/api/billing/webhook
#    Events: checkout.session.completed, customer.subscription.updated,
#            customer.subscription.deleted, invoice.payment_failed
#    Copy the signing secret (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Session ──────────────────────────────────────────────────────────────────
# Session timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# ─── IMAP Notes ───────────────────────────────────────────────────────────────
# For Gmail IMAP: use an App Password, not your regular password
#   https://myaccount.google.com/apppasswords
# For Outlook IMAP: enable IMAP in settings
#   https://support.microsoft.com/en-us/office/pop-imap-and-smtp-settings
# For iCloud: use an app-specific password
#   https://support.apple.com/en-us/HT204397
